# Copy this file to `.env` and fill in your keys. Do NOT commit `.env` (it is git-ignored).

# Google Gemini API key from https://aistudio.google.com/apikey
# (This is loaded and used as GOOGLE_API_KEY by litellm for the "gemini/" provider.)
LLM_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Optional: NCBI E-utilities API key from https://www.ncbi.nlm.nih.gov/account/settings/
# Raises PubMed rate limits during validation. Leave blank to run without one (slower).
NCBI_API_KEY=
